{
  "expo": {
    "name": "島の記録帳",
    "slug": "shima-logbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "catanrankingapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "package": "com.kimama.shimanokirokucho",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#F1DDB3",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "backgroundColor": "#F1DDB3",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 220
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e0234103-e9a8-4b5d-a8eb-bef849391f22"
      }
    }
  }
}
